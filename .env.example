# Trader Assistant 환경변수 예시.
# 실제 사용 시 .env 파일로 복사 후 값 채우기. .env는 git에 커밋하지 X.

# ─────────────────────────────────────────
# 데이터 경로
# ─────────────────────────────────────────
# 일봉/장중/메타 데이터를 저장할 루트 (절대경로 권장).
DATA_DIR=./data

# 로그 디렉토리.
LOG_DIR=./logs

# ─────────────────────────────────────────
# KIS (한국투자증권) Open API
# ─────────────────────────────────────────
# 발급: https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# real | mock  (mock = 모의투자 도메인)
KIS_API_MODE=mock

# ─────────────────────────────────────────
# KIS 멀티 계정 (선택)
# ─────────────────────────────────────────
# 여러 KIS 계정의 키를 동시 사용하면 호출이 라운드 로빈으로 분산되어
# rate limit 이 키 개수만큼 곱셈됨 (초당 20 → 40 → 60...).
# 본인 + 가족 계정 묶어서 모니터링 분산 용도. KIS_APP_KEY_2, _3, _4 ...
# 순차로 채우면 됨. 중간 인덱스가 비면 거기서 스캔 종료.
#
# 주의: 매매(주문 API)는 진행 안 함. 조회 전용 풀이라 명의 분리 이슈 없음.
# 단, 각 키는 본인 명의로 발급받은 것이어야 함 (와이프 키는 와이프 본인이 직접 발급).
# 각 키마다 3개월 미거래 자동 해지 정책이 별도 적용됨.
#KIS_APP_KEY_2=
#KIS_APP_SECRET_2=
#KIS_ACCOUNT_NO_2=
#KIS_LABEL_2=wife

# ─────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────
# @BotFather 에서 생성한 토큰.
TELEGRAM_BOT_TOKEN=
# 메시지를 받을 채팅 ID (개인 채팅 또는 채널).
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────
# SMTP (사후 상세 레포트 발송용)
# ─────────────────────────────────────────
GMAIL_USER=
# Google 계정의 "앱 비밀번호" (2FA 필수).
GMAIL_APP_PASSWORD=
GMAIL_TO=
# SMTP 호스트/포트. 미설정 시 Gmail 기본값 사용.
# 다른 메일 서비스도 가능 (예: Naver = smtp.naver.com:587).
SMTP_HOST=
SMTP_PORT=

# ─────────────────────────────────────────
# 운영 플래그
# ─────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# dry-run = 알림 미발송 (콘솔/파일에만 기록).
DRY_RUN=false

# ─────────────────────────────────────────
# PWA 대시보드 (M7)
# ─────────────────────────────────────────
# 1 | true | yes  → scheduler 가 FastAPI + WebSocket 서버를 별도 daemon thread
# 로 시작. 텔레그램 카드와 동일 데이터를 아이패드 PWA 에서 한 화면에 표시.
# 기본은 비활성화 — 운영에 영향 X.
DASHBOARD_PWA_ENABLED=0

# bind 호스트. 기본 127.0.0.1 (localhost only). Tailscale 안에서 다른 디바이스
# (아이패드/폰) 도 접근하려면 100.x.x.x (Tailscale IP) 또는 0.0.0.0 + Tailscale
# 방화벽 활용. 외부 인터넷 직접 노출 (0.0.0.0 + 포트포워딩) 은 비권장.
DASHBOARD_PWA_HOST=127.0.0.1

# 포트. 기본 8000.
DASHBOARD_PWA_PORT=8000

# M6 모니터링 카드 텔레그램 발송 토글. 1=발송 (default), 0=skip.
# 0 으로 두면 dashboard_tick 의 카드 send/edit/delete 모두 skip — PWA 만
# 갱신. tick 시간 단축 효과 (종목 N개 × Telegram 동기 POST ~200-500ms 직렬
# 제거). 다음은 영향 X — KIS fetch / tick_log / 명령 응답 (/buy /sell /on
# /off) / 14:50 결정 레포트 / 16:00 사후 / 상한가 진입 이벤트.
MONITORING_TELEGRAM_CARDS_ENABLED=1
