# Trader Assistant 환경변수 예시.
# 실제 사용 시 .env 파일로 복사 후 값 채우기. .env는 git에 커밋하지 X.

# ─────────────────────────────────────────
# 데이터 경로
# ─────────────────────────────────────────
# 일봉/장중/메타 데이터를 저장할 루트 (절대경로 권장).
DATA_DIR=./data

# 로그 디렉토리.
LOG_DIR=./logs

# ─────────────────────────────────────────
# KRX 공식 사이트 (pykrx 일부 호출이 인증 요구)
# ─────────────────────────────────────────
# 회원가입: http://open.krx.co.kr
# pykrx>=1.0.40 의 get_market_ohlcv_by_ticker 등은 KRX 인증이 필요하다.
# pykrx 가 os.environ 에서 직접 읽기 때문에 .env 에만 넣으면 자동 적용.
KRX_ID=
KRX_PW=

# ─────────────────────────────────────────
# KIS (한국투자증권) Open API
# ─────────────────────────────────────────
# 발급: https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# real | mock  (mock = 모의투자 도메인)
KIS_API_MODE=mock

# ─────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────
# @BotFather 에서 생성한 토큰.
TELEGRAM_BOT_TOKEN=
# 메시지를 받을 채팅 ID (개인 채팅 또는 채널).
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────
# Gmail SMTP (사후 상세 레포트 발송용)
# ─────────────────────────────────────────
GMAIL_USER=
# Google 계정의 "앱 비밀번호" (2FA 필수).
GMAIL_APP_PASSWORD=
GMAIL_TO=

# ─────────────────────────────────────────
# 운영 플래그
# ─────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# dry-run = 알림 미발송 (콘솔/파일에만 기록).
DRY_RUN=false
